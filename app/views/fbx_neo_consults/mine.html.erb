<h2 class="pageheader"><u>FBX NEOs Asked Of Me </u></h2>
<br>
<br>

<% if @consults.any? %>
  <% @consults.each do |consult| %>
    <div class="consult-card mb-3 p-2 shadow-sm">
      <div class="card-body">
        <h5>
          <%= link_to consult.title, fbx_neo_consult_path(consult) %>
        </h5>

        <p class="text-muted">
          Requested by: <%= consult.asked_by.name %>
        </p>

        <p>
          Assigned team size:
          <strong><%= consult.assigned_users.count %></strong>
        </p>
      </div>
    </div>
  <% end %>
<% else %>
  <p>You have no FBX NEO assignments.</p>
<% end %>
<br>
<hr>
<div id: "conss">
<%= link_to "← Back", :back, class: "btn btn-purple" %>
</div>
<br>
<br>