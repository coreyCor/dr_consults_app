
<h2 class="pageheader">FBX NEOs asked of me </h2>
<br>
<br>

<% if @consults.any? %>
  <% @consults.each do |consult| %>
    <div class="consult-card mb-2 p-2 shadow-sm bg-light">
      <%= link_to fbx_neo_consult_path(consult), class: "text-decoration-none text-dark d-block" do %>
        <div class="card-body">
          <h5><%= consult.title %></h5>
          <p class="text-muted">
            Requested by: <%= consult.asked_by.name %>
          </p>
          <p>
            Assigned team size:
            <strong><%= consult.assigned_users.count %></strong>
          </p>
        </div>
      <% end %>
    </div>
  <% end %>
<% else %>
  <p>You have no FBX NEO assignments.</p>
<% end %>
<br>
<br>
<hr>
<div id="conss">
  <%= link_to "← Back", :back, class: "btn btn-purple" %>
</div>
<br>
<br>