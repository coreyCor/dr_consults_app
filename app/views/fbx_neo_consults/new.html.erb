
<h2 class="pageheader"><u>New FBX Neo Request</u></h2>
<br>
<br>

<div class="row justify-content-center mt-4">
  <div class="col-md-5">
    <div class="card shadow-sm">
      <div class="card-body p-4">

        <h4 class="text-center mb-4 pageheader">New FBX NEO Request</h4>

        <%= form_with model: @consult, url: fbx_neo_consults_path, id: "fbx-form" do |f| %>

          <div class="mb-3">
            <%= f.label :Accession, class: "form-label fw-bold" %>
            <%= f.text_field :title, class: "form-control", required: true, maxlength: 20 %>
          </div>

          <!--<div class="mb-3">
            <%= f.label :Question %>
            <%= f.text_area :body, class: "form-control" %>
          </div>-->

          <div class="mb-3">
            <label class="form-label fw-bold">Select 2–5 recipients</label>
            <% @eligible_users.each do |user| %>
              <div class="form-check">
                <%= check_box_tag "assigned_user_ids[]", user.id, false,
                  class: "form-check-input recipient-checkbox",
                  id: "user_#{user.id}" %>
                <%= label_tag "user_#{user.id}", user.name, class: "form-check-label" %>
              </div>
            <% end %>
            <div class="text-danger small mt-1" id="recipient-error" style="display: none;">
              Please select between 2 and 5 recipients.
            </div>
          </div>

          <div class="d-grid mt-4">
            <%= f.submit "Create FBX NEO", class: "btn btn-purple" %>
          </div>

        <% end %>

      </div>
    </div>
    <div class="mt-3">
      <%= link_to "Back", :back, class: "btn btn-purple" %>
    </div>
  </div>
</div>

<script>
  document.addEventListener("turbo:load", function() {
    const form = document.getElementById("fbx-form");
    if (!form) return;

    form.addEventListener("submit", function(e) {
      const checked = document.querySelectorAll(".recipient-checkbox:checked").length;
      const error = document.getElementById("recipient-error");
      if (checked < 2 || checked > 5) {
        e.preventDefault();
        error.style.display = "block";
      } else {
        error.style.display = "none";
      }
    });
  });
</script>