<div class="container-fluid py-4">
  <h2 class="pageheader">Weekly Schedule</h2>
  <hr>

  <div class="table-responsive">
    <table class="table table-hover align-middle" style="border-radius: 12px; overflow: hidden;">
      <thead style="background-color: #4a90d9; color: white;">
        <tr>
          <th class="px-3 py-3">User</th>
          <th class="px-3 py-3">Time Zone</th>
          <% @days_of_week.each do |day| %>
            <th class="px-3 py-3"><%= day %></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td class="px-3 fw-semibold"><%= user.name %></td>
            <td class="px-3 text-muted small"><%= user.time_zone %></td>
            <% @days_of_week.each_with_index do |day, dow| %>
              <% availability = user.availabilities.find { |a| a.day_of_week == dow } %>
              <td class="px-3">
                <% if availability && availability.start_time && availability.end_time %>
                  <span class="badge rounded-pill px-3 py-2" style="background-color:#463797; color: #ffffff; font-size: 0.8rem;">
                    <%= availability.start_time.strftime("%I:%M") %> - <%= availability.end_time.strftime("%I:%M") %>
                  </span>
                <% else %>
                  <span class="text-muted small">N/A</span>
                <% end %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-3">
    <%= link_to "← Back", :back, class: "btn btn-primary" %>
  </div>
</div>