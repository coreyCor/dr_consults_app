<h2 class="pageheader"><u>Assist </u></h2>

<div class="card mb-3">
  <div class="card-body">
    <h4>
      Accession: <%= @consult.title %>

    </h4>

    <hr>

    <p>
      <strong>Requested by:</strong>
      <%= @consult.asked_by.name %>
    </p>

    <% if @consult.fbx_neo? %>
      <p><strong>Assigned team:</strong></p>
      <ul>
        <% @consult.assigned_users.each do |user| %>
          <li>
            <%= user.name %>
            <span class="text-muted">
              (Local time: <%= user.local_time.strftime("%I:%M %p") %>)
            </span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>
        <strong>Assigned to:</strong>
        <%= @consult.assigned_to&.name || "Unassigned" %>
        <% if @consult.assigned_to %>
          <span class="text-muted">
            (Local time: <%= @consult.assigned_to.local_time.strftime("%I:%M %p") %>)
          </span>
        <% end %>
      </p>
    <% end %>

    <p class="mt-3">
      <strong>Requested on:</strong>
      <%= @consult.created_at.in_time_zone("Pacific Time (US & Canada)").strftime("%b %d, %Y %I:%M %p") %>
    </p>
    <br>
          <% if @consult.fbx_neo? %>
        <small class="text-danger text-decoration-underline ms-1">FBX NEO</small>
      <% end %>
  </div>
</div>

<%= link_to "← Back", :back, class: "btn btn-purple" %>