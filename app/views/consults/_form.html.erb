<div class="row justify-content-center mt-4">
  <div class="col-md-5">
    <div class="card shadow-lg">
      <div class="card-body p-4 bg-light">
        <h4 class="text-center mb-4 ">New Assist Request</h4>
        <br>
        <br>

        <%= form_with(model: @consult, local: true) do |f| %>
          <% if @consult.errors.any? %>
            <div class="alert alert-danger">
              <h4>Errors:</h4>
              <ul>
                <% @consult.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="mb-3">
            <%= f.label :accession, class: "form-label fw-bold" %>
            <%= f.text_field :title, class: "form-control", required: true, maxlength: 20 %>
          </div>

          <div class="mb-3">
            <%= f.label :assigned_to_id, "Doctor:", class: "form-label fw-bold" %>
            <%= f.collection_select :assigned_to_id,
              @eligible_users || [],
              :id,
              :name,
              { prompt: "Select a doctor" },
              { class: "form-select", required: true } %>
          </div>
          <br>
          <br>
          <div class="d-grid mt-4">
            <%= f.submit "Submit Assist", class: "btn btn-purple " %>
          </div>

        <% end %>

      </div>
    </div>
    <br>
    <br>
    <div class="mt-3">
      <%= link_to "← Back", :back, class: "btn btn-purple" %>
    </div>

  </div>
</div>
<br>
<br>
<hr>
<br>
<br>